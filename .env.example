# PawStream Configuration
# Copy this file to .env and update the values:
#   cp .env.example .env

# Your domain name (used for Caddy HTTPS and MediaMTX WebRTC)
# Use "localhost" for local development (Caddy will use self-signed cert)
DOMAIN=pawstream.example.com

# JWT secret for user authentication (CHANGE THIS!)
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# Encryption key for device secrets at rest (optional but recommended)
# Generate one: openssl rand -hex 32
ENCRYPTION_KEY=

# MediaMTX WebRTC URL (how browsers reach the WebRTC endpoint)
# For HTTPS deployments: https://your-domain:443
# For local dev: http://localhost:8889
MEDIAMTX_WEBRTC_URL=https://pawstream.example.com

# CORS allowed origins (comma-separated, or "*" for all)
# For production, set to your domain: https://pawstream.example.com
CORS_ORIGINS=https://pawstream.example.com
