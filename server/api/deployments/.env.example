# PawStream Docker Compose Configuration
# Copy this file to .env and edit the values

# JWT signing secret (REQUIRED - change this!)
JWT_SECRET=your-random-secret-here-at-least-32-chars

# AES-256 encryption key for device secrets (optional, 32+ chars)
ENCRYPTION_KEY=your-encryption-key-at-least-32-chars

# Your server's external IP or domain (for WebRTC ICE candidates)
EXTERNAL_IP=192.168.1.100

# MediaMTX URLs that clients will connect to
MEDIAMTX_WEBRTC_URL=http://192.168.1.100:8889
MEDIAMTX_RTSP_URL=rtsp://192.168.1.100:8554

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGINS=*
